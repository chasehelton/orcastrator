{
  "name": "@chasehelton/orcastrator",
  "version": "0.2.0",
  "description": "Lightweight CLI-first multi-agent coding runtime built on GitHub Copilot SDK",
  "type": "module",
  "bin": {
    "orcastrator": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/config/builder.d.ts",
      "default": "./dist/config/builder.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "copilot",
    "multi-agent",
    "cli",
    "ai"
  ],
  "author": "Chase Helton",
  "license": "MIT",
  "dependencies": {
    "@github/copilot-sdk": "^0.2.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
